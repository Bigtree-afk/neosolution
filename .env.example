# ──────────────────────────────────
# NeoSolution 환경변수 템플릿
# .env로 복사 후 값 입력
# GitHub Actions에서는 Repository Secrets 사용
# ──────────────────────────────────

# === AI API ===
ANTHROPIC_API_KEY=sk-ant-...

# === 뉴스 수집 ===
NEWS_API_KEY=...

# === 공공 데이터 API ===
KOSIS_API_KEY=...
BOK_API_KEY=...
KAMIS_API_KEY=...
DATA_GO_KR_API_KEY=...

# === Cloudflare R2 (이미지 스토리지) ===
R2_ACCESS_KEY=...
R2_SECRET_KEY=...
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://images.neosolution.co.kr

# === Cloudflare Pages (사이트 배포) ===
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...

# === Telegram ===
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
TELEGRAM_CHANNEL_KO=@neosolution_ko

# === Naver Blog ===
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...
NAVER_BLOG_ID=...

# === KakaoTalk 채널 ===
KAKAO_REST_API_KEY=...
KAKAO_CHANNEL_ID=...

# === Instagram ===
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...
